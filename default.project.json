{
  "name": "Turf Wars",
  "syncback": {
    "ignoreGlobs": ["Packages/"]
  },
  "tree": {
    "$className": "DataModel",
    "ReplicatedFirst": {
      "Client": {
        "$path": "src/Client"
      }
    },
    "ReplicatedStorage": {
      "$path": "src/Shared",
      "Packages": {
        "$path": "Packages/"
      },
      "$keepUnknowns": true
    },
    "ServerScriptService": {
      "Server": {
        "$path": "src/Server"
      }
    }
  }
}
